{
  "openapi": "3.0.3",
  "info": {
    "title": "Alumni Influencers Public Developer API",
    "description": "Public developer API for accessing the featured alumnus and alumni analytics data using bearer tokens.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost/practice/cw/index.php",
      "description": "Local development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "API Token"
      }
    },
    "schemas": {
      "AlumniProfile": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 3
          },
          "user_id": {
            "type": "integer",
            "example": 3
          },
          "first_name": {
            "type": "string",
            "example": "Amal"
          },
          "last_name": {
            "type": "string",
            "example": "Perera"
          },
          "email": {
            "type": "string",
            "example": "amal@iit.ac.lk"
          },
          "university_email": {
            "type": "string",
            "example": "amal@iit.ac.lk"
          },
          "phone_number": {
            "type": "string",
            "example": "0712345678"
          },
          "date_of_birth": {
            "type": "string",
            "format": "date",
            "example": "2000-05-06"
          },
          "graduation_year": {
            "type": "integer",
            "example": 2026
          },
          "current_job_title": {
            "type": "string",
            "example": "Software Engineer"
          },
          "current_company": {
            "type": "string",
            "example": "WSO2"
          },
          "industry_sector": {
            "type": "string",
            "example": "Software Engineering"
          },
          "location_city": {
            "type": "string",
            "example": "Colombo"
          },
          "location_country": {
            "type": "string",
            "example": "Sri Lanka"
          },
          "biography": {
            "type": "string",
            "example": "Computer Science graduate working as a software engineer."
          },
          "linkedin_url": {
            "type": "string",
            "example": "https://www.linkedin.com/in/example-user"
          },
          "profile_image": {
            "type": "string",
            "example": "profile_123.png"
          },
          "programmes": {
            "type": "string",
            "example": "BSc Computer Science"
          },
          "degrees": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "certifications": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "licences": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "short_courses": {
            "type": "array",
            "items": {
              "type": "object"
            }
          },
          "employment_history": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "FeaturedTodayResponse": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date",
            "example": "2026-05-06"
          },
          "featured_alumnus": {
            "$ref": "#/components/schemas/AlumniProfile"
          }
        }
      },
      "AlumniListResponse": {
        "type": "object",
        "properties": {
          "filters": {
            "type": "object",
            "properties": {
              "programme": {
                "type": "string",
                "example": "BSc Computer Science"
              },
              "graduation_year": {
                "type": "integer",
                "example": 2026
              },
              "industry_sector": {
                "type": "string",
                "example": "Software Engineering"
              }
            }
          },
          "count": {
            "type": "integer",
            "example": 2
          },
          "alumni": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AlumniProfile"
            }
          }
        }
      },
      "AnalyticsSummaryResponse": {
        "type": "object",
        "properties": {
          "total_alumni": {
            "type": "integer",
            "example": 12
          },
          "total_profiles": {
            "type": "integer",
            "example": 10
          },
          "total_certifications": {
            "type": "integer",
            "example": 18
          },
          "total_courses": {
            "type": "integer",
            "example": 15
          },
          "top_industry_sector": {
            "type": "object",
            "example": {
              "industry_sector": "Software Engineering",
              "total": 5
            }
          },
          "top_job_title": {
            "type": "object",
            "example": {
              "current_job_title": "Software Engineer",
              "total": 4
            }
          },
          "top_employer": {
            "type": "object",
            "example": {
              "current_company": "WSO2",
              "total": 3
            }
          }
        }
      },
      "AnalyticsChartsResponse": {
        "type": "object",
        "properties": {
          "alumni_by_graduation_year": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChartDataPoint"
            }
          },
          "employment_by_industry": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChartDataPoint"
            }
          },
          "top_employers": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChartDataPoint"
            }
          },
          "common_job_titles": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChartDataPoint"
            }
          },
          "geographic_distribution": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChartDataPoint"
            }
          },
          "certification_trends": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChartDataPoint"
            }
          },
          "course_trends": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ChartDataPoint"
            }
          }
        }
      },
      "ChartDataPoint": {
        "type": "object",
        "properties": {
          "label": {
            "type": "string",
            "example": "Software Engineering"
          },
          "total": {
            "type": "integer",
            "example": 5
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "string",
            "example": "Missing bearer token."
          }
        }
      }
    }
  },
  "paths": {
    "/api/featured-today": {
      "get": {
        "summary": "Get today's featured alumnus",
        "description": "Returns the alumnus featured for the current day. Intended for the Mobile AR App client. Requires the read:alumni_of_day scope.",
        "tags": [
          "Featured Alumnus"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Featured alumnus returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FeaturedTodayResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing, invalid, expired, or revoked bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - valid token but missing required scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "No featured alumnus found for today",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/alumni": {
      "get": {
        "summary": "Get filtered alumni records",
        "description": "Returns alumni profile records with optional filters for programme, graduation year, and industry sector. Intended for the Analytics Dashboard client. Requires the read:alumni scope.",
        "tags": [
          "Analytics API"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "parameters": [
          {
            "name": "programme",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter alumni by degree/programme name"
          },
          {
            "name": "graduation_year",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Filter alumni by graduation year"
          },
          {
            "name": "industry_sector",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Filter alumni by industry sector"
          }
        ],
        "responses": {
          "200": {
            "description": "Filtered alumni records returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AlumniListResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing, invalid, expired, or revoked bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - valid token but missing required scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/analytics-summary": {
      "get": {
        "summary": "Get analytics summary",
        "description": "Returns summary metrics for the University Analytics Dashboard. Requires the read:analytics scope.",
        "tags": [
          "Analytics API"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Analytics summary returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsSummaryResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing, invalid, expired, or revoked bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - valid token but missing required scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/analytics-charts": {
      "get": {
        "summary": "Get analytics chart data",
        "description": "Returns chart-ready alumni analytics data for the University Analytics Dashboard. Requires the read:analytics scope.",
        "tags": [
          "Analytics API"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "responses": {
          "200": {
            "description": "Analytics chart data returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AnalyticsChartsResponse"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized - missing, invalid, expired, or revoked bearer token",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "Forbidden - valid token but missing required scope",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}